<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Phase 1 — Document number sequences -->
    <data noupdate="1">

        <record id="seq_fm_job_complaint" model="ir.sequence">
            <field name="name">FM Job Complaint</field>
            <field name="code">fm.job.complaint</field>
            <field name="prefix">FM/COMP/%(year)s/</field>
            <field name="padding">4</field>
            <field name="number_increment">1</field>
            <field name="number_next">1</field>
            <field name="implementation">no_gap</field>
        </record>

