<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_fm_contractor_list" model="ir.ui.view">
        <field name="name">fm.contractor.list</field>
        <field name="model">fm.contractor</field>
        <field name="arch" type="xml">
            <tree string="Contractors">
                <field name="name"/>
                <field name="contractor_type"/>
                <field name="branch_id"/>
                <field name="partner_id"/>
            </tree>
        </field>
    </record>

    <record id="view_fm_contractor_form" model="ir.ui.view">
        <field name="name">fm.contractor.form</field>
        <field name="model">fm.contractor</field>
        <field name="arch" type="xml">
            <form string="Contractor">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="contractor_type"/>
                            <field name="partner_id"/>
                            <field name="active" invisible="1"/>
                        </group>
                        <group>
                            <field name="branch_id"/>
                            <field name="user_ids" widget="many2many_tags"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Inventory" name="inventory">
                            <field name="inventory_line_ids">
                                <tree editable="bottom">
                                    <field name="product_id"/>
                                    <field name="quantity_issued"/>
                                    <field name="quantity_consumed"/>
                                    <field name="quantity_balance"/>
                                    <field name="uom_id"/>
                                    <field name="last_updated"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_fm_contractor_search" model="ir.ui.view">
        <field name="name">fm.contractor.search</field>
        <field name="model">fm.contractor</field>
        <field name="arch" type="xml">
            <search string="Contractors">
                <field name="name"/>
                <field name="branch_id"/>
                <field name="partner_id"/>
                <filter string="Archived" name="inactive" domain="[('active', '=', False)]"/>
                <group expand="0" string="Group By">
                    <filter string="Branch" name="group_branch" context="{'group_by': 'branch_id'}"/>
                    <filter string="Contractor Type" name="group_type" context="{'group_by': 'contractor_type'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_fm_contractor" model="ir.actions.act_window">
        <field name="name">Contractors</field>
        <field name="res_model">fm.contractor</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_fm_contractor_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smart_action">
                Register a new Facilities Management contractor.
            </p>
        </field>
    </record>

</odoo>
