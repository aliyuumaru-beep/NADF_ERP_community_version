<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_fm_consumable_request_list" model="ir.ui.view">
        <field name="name">fm.consumable.request.list</field>
        <field name="model">fm.consumable.request</field>
        <field name="arch" type="xml">
            <tree string="Consumable Requests"
                  decoration-info="state in ('draft', 'submitted')"
                  decoration-success="state == 'approved'"
                  decoration-danger="state == 'rejected'">
                <field name="name"/>
                <field name="job_order_id"/>
                <field name="schedule_id"/>
                <field name="contractor_id"/>
                <field name="request_date"/>
                <field name="state" widget="badge"
                       decoration-info="state in ('draft', 'submitted')"
                       decoration-success="state == 'approved'"
                       decoration-danger="state == 'rejected'"/>
            </tree>
        </field>
    </record>

    <record id="view_fm_consumable_request_form" model="ir.ui.view">
        <field name="name">fm.consumable.request.form</field>
        <field name="model">fm.consumable.request</field>
        <field name="arch" type="xml">
            <form string="Consumable Request">
                <header>
                    <button name="action_submit" type="object" string="Submit"
                            class="oe_highlight" invisible="state != 'draft'"
                            groups="nadf_facilities_management.group_fm_tff_contractor,nadf_facilities_management.group_fm_branch_desk_officer"/>
                    <button name="action_approve" type="object" string="Approve"
                            class="oe_highlight" invisible="state != 'submitted'"
                            groups="nadf_facilities_management.group_fm_branch_desk_officer"/>
                    <button name="action_reject" type="object" string="Reject"
                            invisible="state != 'submitted'"
                            groups="nadf_facilities_management.group_fm_branch_desk_officer"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,submitted,approved"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="job_order_id"/>
                            <field name="schedule_id"/>
                            <field name="contractor_id" readonly="1"/>
                            <field name="branch_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="request_date"/>
                            <field name="approved_by" readonly="1"/>
                            <field name="approval_date" readonly="1"/>
                        </group>
                    </group>
                    <field name="line_ids">
                        <tree editable="bottom">
                            <field name="product_id"/>
                            <field name="description"/>
                            <field name="quantity_requested"/>
                            <field name="quantity_approved"/>
                            <field name="uom_id"/>
                            <field name="unit_cost"/>
                            <field name="total_cost" sum="Total"/>
                        </tree>
                    </field>
                    <group string="Desk Officer Notes">
                        <field name="desk_officer_notes" nolabel="1"/>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_fm_consumable_request_search" model="ir.ui.view">
        <field name="name">fm.consumable.request.search</field>
        <field name="model">fm.consumable.request</field>
        <field name="arch" type="xml">
            <search string="Consumable Requests">
                <field name="name"/>
                <field name="job_order_id"/>
                <field name="schedule_id"/>
                <field name="contractor_id"/>
                <filter string="Draft" name="filter_draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Submitted" name="filter_submitted" domain="[('state', '=', 'submitted')]"/>
                <filter string="Approved" name="filter_approved" domain="[('state', '=', 'approved')]"/>
                <group expand="0" string="Group By">
                    <filter string="Contractor" name="group_contractor" context="{'group_by': 'contractor_id'}"/>
                    <filter string="Job Order" name="group_job_order" context="{'group_by': 'job_order_id'}"/>
                    <filter string="Maintenance Schedule" name="group_schedule" context="{'group_by': 'schedule_id'}"/>
                    <filter string="Status" name="group_state" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_fm_consumable_request" model="ir.actions.act_window">
        <field name="name">Consumable Requests</field>
        <field name="res_model">fm.consumable.request</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_fm_consumable_request_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smart_action">
                Raise a new consumable / material request against a job order.
            </p>
        </field>
    </record>

</odoo>
